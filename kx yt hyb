def check_license(user_key):
    try:
        req = requests.get(LICENSE_URL).text
        for line in req.split('\n'):
            line = line.strip()
            if line.startswith(f"L={user_key},EXP="):
                exp_date_str = line.split("EXP=")[1].strip()
                exp_date = datetime.strptime(exp_date_str, "%d-%m-%Y")
                if datetime.now() > exp_date:
                    return False, "EXPIRED", exp_date_str
                return True, "ACTIVE", exp_date_str
        return False, "INVALID", None
    except:
        print(Fore.RED + "  [-] Internet Connection Error!")
        sys.exit()

