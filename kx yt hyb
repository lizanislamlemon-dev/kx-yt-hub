# AI & UPLOAD ENGINE
# ==========================================
def generate_seo(topic):
    if not os.path.exists('gemini_api.txt'):
        print(Fore.RED + "  [X] Error: 'gemini_api.txt' file is missing!")
        sys.exit()
    with open('gemini_api.txt', 'r') as f:
        api_key = f.read().strip()
        
    genai.configure(api_key=api_key)
    model = genai.GenerativeModel('gemini-pro')
    try:
        res = model.generate_content(f"Create a viral YouTube title, short description, and 15 comma-separated tags for: {topic}. Output ONLY in JSON format: {{\"title\": \"...\", \"description\": \"...\", \"tags\": [\"...\", \"...\"]}}").text
        return json.loads(res.replace("```json", "").replace("```", "").strip())
    except:
        return {"title": topic, "description": "Auto Uploaded via KX YT HUB", "tags": ["kxythub"]}

def process_video(youtube, chat_id, url=None, query=None):
    send_tg(chat_id, "⏳ *Process Started:* Downloading Media...")
    print(Fore.CYAN + "\n  [~] Phase 1: Downloading High-Quality Media...")
    
    opts = {'format': 'best', 'outtmpl': 'video.mp4', 'writethumbnail': True, 'quiet': True}
    search = f"{query} creative commons" if query else url

    try:
        with yt_dlp.YoutubeDL(opts) as ydl:
            info = ydl.extract_info(search, download=True)
            video_title = info.get('title', 'Video')
        print(Fore.GREEN + "  [✔] Download Successful!")
    except:
        print(Fore.RED + "  [X] Download Failed!")
        send_tg(chat_id, "❌ *Error:* Download Failed!")
        return

    send_tg(chat_id, "🤖 *Process:* AI generating viral SEO...")
    loading_bar("Phase 2: Generating AI SEO & Tags")
    seo = generate_seo(video_title)
    
    send_tg(chat_id, "🚀 *Process:* Pushing to YouTube Server...")
    loading_bar("Phase 3: Uploading to YouTube Channel")
    
    try:
        thumb = next((f for f in os.listdir('.') if f.startswith('video.') and f.endswith(('.jpg', '.webp', '.png'))), None)
        body = {'snippet': {'title': seo['title'][:100], 'description': seo['description'], 'tags': seo['tags'], 'categoryId': '22'}, 'status': {'privacyStatus': 'public'}}
        
        req = youtube.videos().insert(part='snippet,status', body=body, media_body=MediaFileUpload('video.mp4', chunksize=-1, resumable=True))
        vid_id = req.execute().get('id')
        
        if thumb:
            youtube.thumbnails().set(videoId=vid_id, media_body=MediaFileUpload(thumb)).execute()

        os.remove('video.mp4')
        if thumb: os.remove(thumb)

        print(Fore.GREEN + Style.BRIGHT + f"\n  [✔] UPLOAD SUCCESS! URL: https://youtu.be/{vid_id}")
        send_tg(chat_id, f"✅ *SUCCESSFULLY UPLOADED!*\n\n📌 *Title:* {seo['title']}\n🔗 *Watch:* https://youtu.be/{vid_id}")

    except Exception as e:
        print(Fore.RED + f"  [X] Upload Failed: {e}")
        send_tg(chat_id, f"❌ *Error:* Upload Failed!\nLog: {e}")

