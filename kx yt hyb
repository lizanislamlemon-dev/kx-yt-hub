def parse_date_time(date_str, time_str, ampm_opt):
    ampm = "AM" if ampm_opt == '1' else "PM"
    try:
        time_obj = datetime.strptime(f"{time_str} {ampm}", "%I:%M %p")
        time_24 = time_obj.strftime("%H:%M")
        full_dt_str = f"{date_str} {time_24}"
        scheduled_dt = datetime.strptime(full_dt_str, "%d-%m-%Y %H:%M")
        
        if scheduled_dt <= datetime.now():
            return None, "PAST_TIME"
            
        local_tz_offset = time.strftime('%z')
        formatted_offset = f"{local_tz_offset[:3]}:{local_tz_offset[3:]}" if local_tz_offset else "Z"
        iso_time = scheduled_dt.strftime(f"%Y-%m-%dT%H:%M:00{formatted_offset}")
        readable_time = f"{date_str} at {time_str} {ampm}"
        
        return {"iso": iso_time, "readable": readable_time, "datetime": scheduled_dt, "offset": formatted_offset}, "SUCCESS"
    except Exception as e:
        return None, str(e)

