def check_license(user_key):
    local_hwid = get_hwid()
    try:
        req = requests.get(LICENSE_URL).text
        for line in req.split('\n'):
            line = line.strip()
            if line.startswith(f"L={user_key},EXP="):
                parts = line.split(",")
                exp_date_str = [p for p in parts if p.startswith("EXP=")][0].split("=")[1]
                exp_date = datetime.strptime(exp_date_str, "%d-%m-%Y")
                
                perms = {"trend": False, "switch": False, "exp": exp_date_str, "chat_id": None}
                
                # Check HWID
                hwid_part = [p for p in parts if p.startswith("HWID=")]
                if hwid_part:
                    server_hwid = hwid_part[0].split("=")[1].strip()
                    if server_hwid != local_hwid:
                        return False, "HWID_LOCKED", perms
                else:
                    return False, "HWID_MISSING", perms
                
                if datetime.now() > exp_date:
                    return False, "EXPIRED", perms
                    
                perms["trend"] = "TREND=1" in line
                perms["switch"] = "SWITCH=1" in line
                return True, "ACTIVE", perms
        return False, "INVALID", None
    except:
        print(Fore.RED + "  [-] Internet Connection Error!")
        sys.exit()

