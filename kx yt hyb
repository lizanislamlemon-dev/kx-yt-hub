# ADVANCED AI SEO ENGINE (with Bulletproof Regex JSON Extractor)
# ==========================================
def generate_seo(topic):
    if not os.path.exists('gemini_api.txt'):
        print(Fore.RED + "  [X] Error: 'gemini_api.txt' file is missing!")
        sys.exit()
    with open('gemini_api.txt', 'r') as f:
        api_key = f.read().strip()
        
    url = f"https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key={api_key}"
    
    prompt = f"""
    You are an expert YouTube SEO and Algorithm Growth Specialist.
    Analyze this original video title: "{topic}".
    
    CRITICAL INSTRUCTIONS:
    1. STRIP/REMOVE any original channel names, brand names, radio station names (e.g., "Radio Foorti", "Bhoot FM"), user mentions (e.g., "@username"), hashtags (e.g., "#channelname"), episode numbers, dates, or personal branding from the title.
    2. Identify the core topic of the video (e.g., Bangla ghost story, funny clips, gaming).
    3. Generate a completely fresh, highly engaging, clickbaity, and viral title (under 90 characters) in the same language as the original title.
    4. Generate a highly professional description with a strong call-to-action (Subscribe, Like).
    5. Generate 15 hyper-relevant, high-traffic, and trending YouTube search tags specifically tailored to this core topic to help the video rank in search and recommend feeds.
    
    Output ONLY in this strict JSON format:
    {{
      "title": "Viral Title Here",
      "description": "Engaging description with tags...",
      "tags": ["tag1", "tag2", "tag3", ...]
    }}
    """
    
    payload = {"contents": [{"parts": [{"text": prompt}]}]}
    
    try:
        req = requests.post(url, json=payload).json()
        if 'error' in req:
            print(Fore.RED + f"  [X] Gemini API Error: {req['error']['message']}")
            raise Exception(req['error']['message'])
            
        res_text = req['candidates'][0]['content']['parts'][0]['text']
        
        # Smart Regex JSON Extractor (Even extracts from messy markdown!)
        match = re.search(r'\{.*\}', res_text, re.DOTALL)
        if match:
            seo_data = json.loads(match.group(0))
            if 'title' in seo_data and 'description' in seo_data and 'tags' in seo_data:
                return seo_data
        raise Exception("Invalid AI Response Structure")
    except Exception as e:
        print(Fore.RED + f"  [X] SEO Generation Failed: {e}. Using Default SEO!")
        return {"title": topic[:90], "description": "Auto Uploaded via KX YT HUB", "tags": ["kxythub", "viral"]}

