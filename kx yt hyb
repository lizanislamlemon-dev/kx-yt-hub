# ==========================================
# CORE PROCESS VIDEO (with Strict MP4 & Wildcard Cleanup)
# ==========================================
def process_video(youtube, chat_id, url=None, query=None, auto_schedule_iso=None, auto_schedule_readable=None):
    if auto_schedule_iso:
        schedule_iso = auto_schedule_iso
        schedule_readable = auto_schedule_readable
    else:
        schedule_iso, schedule_readable = get_schedule_time()

    send_tg(chat_id, "⏳ *Process Started:* Downloading Media...")
    print(Fore.CYAN + "\n  [~] Phase 1: Downloading High-Quality Media...")
    
    # Strict MP4 settings to prevent deletion failures
    opts = {
        'format': 'bestvideo[ext=mp4]+bestaudio[ext=m4a]/best[ext=mp4]/best', 
        'outtmpl': 'video.mp4', 
        'writethumbnail': True, 
        'quiet': True,
        'merge_output_format': 'mp4',
        'postprocessors': [{
            'key': 'FFmpegThumbnailsConvertor',
            'format': 'jpg',
        }]
    }
    search = f"{query} creative commons" if query else url

    try:
        with yt_dlp.YoutubeDL(opts) as ydl:
            info = ydl.extract_info(search, download=True)
            video_title = info.get('title', 'Video')
        print(Fore.GREEN + "  [✔] Download Successful!")
    except:
        print(Fore.RED + "  [X] Download Failed!")
        send_tg(chat_id, "❌ *Error:* Download Failed!")
        return

    send_tg(chat_id, "🤖 *Process:* AI generating viral SEO...")
    loading_bar("Phase 2: Generating AI SEO & Tags")
    seo = generate_seo(video_title)
    
    send_tg(chat_id, "🚀 *Process:* Pushing to YouTube Server...")
    loading_bar("Phase 3: Uploading to YouTube Channel")
    
    try:
        thumb = next((f for f in os.listdir('.') if f.startswith('video.') and f.endswith(('.jpg', '.jpeg', '.png'))), None)
        
        status_config = {}
        if schedule_iso:
            status_config['privacyStatus'] = 'private'
            status_config['publishAt'] = schedule_iso
        else:
            status_config['privacyStatus'] = 'public'

        body = {
            'snippet': {
                'title': seo['title'][:100], 
                'description': seo['description'], 
                'tags': seo['tags'], 
                'categoryId': '22'
            }, 
            'status': status_config
        }
        
        req = youtube.videos().insert(part='snippet,status', body=body, media_body=MediaFileUpload('video.mp4', chunksize=-1, resumable=True))
        vid_id = req.execute().get('id')
        
        if thumb:
            try:
                youtube.thumbnails().set(videoId=vid_id, media_body=MediaFileUpload(thumb)).execute()
                print(Fore.GREEN + "  [✔] Thumbnail uploaded successfully!")
            except Exception as thumb_err:
                print(Fore.YELLOW + f"  [!] Thumbnail skipped (New/Unverified Channel limitation)")
                send_tg(chat_id, f"⚠️ *Thumbnail Skipped:* Custom thumbnails require phone verification on your YouTube channel.")

        # Wildcard Auto-Cleanup (Deletes any temporary download files instantly!)
        for file in os.listdir('.'):
            if file.startswith('video'):
                try:
                    os.remove(file)
                except:
                    pass

        if schedule_iso:
            success_msg = f"📅 *VIDEO SCHEDULED SUCCESSFULLY!*\n\n📌 *Title:* {seo['title']}\n⏰ *Scheduled For:* {schedule_readable}\n🔗 *Watch Link:* https://youtu.be/{vid_id}"
            print(Fore.GREEN + Style.BRIGHT + f"\n  [✔] SCHEDULED SUCCESS! Target: {schedule_readable}")
        else:
            success_msg = f"✅ *VIDEO UPLOADED SUCCESSFULLY!*\n\n📌 *Title:* {seo['title']}\n🔗 *Watch Link:* https://youtu.be/{vid_id}"
            print(Fore.GREEN + Style.BRIGHT + f"\n  [✔] UPLOAD SUCCESS! URL: https://youtu.be/{vid_id}")
            
        send_tg(chat_id, success_msg)

    except Exception as e:
        print(Fore.RED + f"  [X] Upload Failed: {e}")
        send_tg(chat_id, f"❌ *Error:* Upload Failed!\nLog: {e}")

