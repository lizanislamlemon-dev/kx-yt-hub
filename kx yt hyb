    print(Fore.WHITE + "  ║ Automate multiple video uploads seamlessly  ║")
    print(Fore.WHITE + "  ║ with custom timers for maximum virality!     ║")
    print(Fore.MAGENTA + "  ╚══════════════════════════════════════════════╝\n")
    
    try:
        count = int(input(Fore.CYAN + "  [?] How many videos do you want to upload today? : ").strip())
    except:
        print(Fore.RED + "  [X] Invalid number!")
        time.sleep(2)
        return
        
    urls = []
    for i in range(count):
        url = input(Fore.GREEN + f"  [>] Enter Video {i+1} URL: ").strip()
        urls.append(url)
        
    print(Fore.CYAN + "\n  ╔══════ [ SELECT VIRAL TIME GAP ] ══════════════╗")
    print(Fore.WHITE + "  ║ [1] Every 4 Hours (Best for YouTube Shorts)  ║")
    print(Fore.WHITE + "  ║ [2] Every 6 Hours (Recommended for Videos)   ║")
    print(Fore.WHITE + "  ║ [3] Every 12 Hours (Daily 2 Videos)          ║")
    print(Fore.WHITE + "  ║ [4] Every 24 Hours (Daily 1 Video)           ║")
    print(Fore.CYAN + "  ╚═══════════════════════════════════════════════╝\n")
    
    gap_choice = input(Fore.CYAN + "  [?] Select Option (1-4): ").strip()
    gap_hours = 6
    if gap_choice == '1': gap_hours = 4
    elif gap_choice == '2': gap_hours = 6
    elif gap_choice == '3': gap_hours = 12
    elif gap_choice == '4': gap_hours = 24
    
    print(Fore.YELLOW + "\n  [!] Set Start Schedule Time for First Video:")
    date_in = input(Fore.GREEN + "  [>] Start Date (DD-MM-YYYY) [e.g., 25-12-2024]: ").strip()
    time_in = input(Fore.GREEN + "  [>] Start Time (HH:MM) [e.g., 05:45]: ").strip()
    ampm_opt = input(Fore.GREEN + "  [>] Select AM/PM (1 for AM, 2 for PM): ").strip()
    
    data, status = parse_date_time(date_in, time_in, ampm_opt)
    if not data:
        print(Fore.RED + f"\n  [X] Scheduling Failed: {status}")
        time.sleep(2)
        return
        
    current_time = data["datetime"]
    offset = data["offset"]
    
    print(Fore.GREEN + f"\n  [✔] Ready to queue {count} videos on Autopilot!")
    print(Fore.YELLOW + f"  [*] Time interval set: Every {gap_hours} Hours.\n")
    time.sleep(2)
    
    for idx, url in enumerate(urls):
        iso_time = current_time.strftime(f"%Y-%m-%dT%H:%M:00{offset}")
        readable_time = current_time.strftime("%d-%m-%Y at %I:%M %p")
        
        print(Fore.MAGENTA + f"\n================================================")
        print(Fore.YELLOW + f"  🚀 Processing Queue Video {idx+1} of {count}")
        print(Fore.CYAN + f"  📅 Target Schedule: {readable_time}")
        print(Fore.MAGENTA + f"================================================")
        
        process_video(youtube, chat_id, url=url, auto_schedule_iso=iso_time, auto_schedule_readable=readable_time)
        
        # Auto-increment the schedule time for the next video
        current_time += timedelta(hours=gap_hours)
        
    print(Fore.GREEN + Style.BRIGHT + "\n  [✔] ALL BULK VIDEOS SCHEDULED SUCCESSFULLY!")
    time.sleep(3)

