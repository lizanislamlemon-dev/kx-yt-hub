def scrape_competitor_tags(youtube, query):
    print(Fore.YELLOW + "  [~] Scanning Competitor Search Results...")
    competitor_tags = []
    try:
        search_res = youtube.search().list(q=query, part="snippet", maxResults=3, type="video").execute()
        video_ids = [item['id']['videoId'] for item in search_res.get('items', []) if 'videoId' in item['id']]
        
        if video_ids:
            videos_res = youtube.videos().list(id=",".join(video_ids), part="snippet").execute()
            for item in videos_res.get('items', []):
                tags = item['snippet'].get('tags', [])
                competitor_tags.extend(tags)
        # return top unique tags
        return list(set(competitor_tags))[:8]
    except Exception as e:
        return []

