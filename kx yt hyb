        api_key = f.read().strip()
        
    url = f"https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key={api_key}"
    
    prompt = f"""
    You are an expert YouTube SEO and Algorithm Growth Specialist.
    Analyze this original video title: "{topic}".
    
    CRITICAL INSTRUCTIONS:
    1. STRIP/REMOVE any original channel names, brand names, radio station names (e.g., "Radio Foorti", "Bhoot FM"), user mentions (e.g., "@username"), hashtags (e.g., "#channelname"), episode numbers, dates, or personal branding from the title.
